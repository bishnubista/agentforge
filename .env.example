# App
NEXT_PUBLIC_APP_NAME=Moneymaker
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=true
USE_LIVE_DATA=true
CACHE_TTL_SECONDS=21600

# LLM: Qwen Cloud primary option
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=

# LLM: Z.ai fallback option
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=

# Optional model routing fallback
TOKENROUTER_API_KEY=
TOKENROUTER_BASE_URL=https://api.tokenrouter.io
TOKENROUTER_MODEL=

# Live web/search data
BRIGHT_DATA_API_KEY=
BRIGHTDATA_API_TOKEN=
BRIGHT_DATA_ZONE=
BRIGHT_DATA_SERP_ZONE=

# Optional database/cache vendor
BUTTERBASE_API_KEY=
BUTTERBASE_APP_ID=
BUTTERBASE_BASE_URL=
BUTTERBASE_API_BASE=

# Optional persistent memory
EVEROS_API_KEY=
EVEROS_BASE_URL=https://api.evermind.ai

# Optional GPU/inference stretch
NOSANA_API_KEY=

# Optional local/dev overrides
RECOMMENDATION_CACHE_DIR=data/cache
MAX_RETAILERS=8
MIN_RETAILER_RESULTS=2
BRIGHT_DATA_TIMEOUT_MS=9000
LLM_TIMEOUT_MS=4000
BUTTERBASE_TIMEOUT_MS=1500
